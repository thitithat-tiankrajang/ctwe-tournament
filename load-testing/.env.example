# Required public tournament page.
TOURNAMENT_URL=http://localhost:3000/tour/your-slug

# Direct public API/backend origins. In production these usually point to Render.
PUBLIC_API_ORIGIN=http://localhost:8080
BACKEND_ORIGIN=http://localhost:8080

# Full capacity stages. Use 1,2 for a local harness smoke test only.
STAGES=100,250,500,750,1000,1500,2000,2500,3000,4000,5000,6000,7000,8000,9000,10000
RAMP_SECONDS=30
SETTLE_SECONDS=10
HOLD_SECONDS=90
SAMPLE_SECONDS=5
STOP_ON_FAIL=true

# Required for real CPU/RAM/GC/Hikari/Tomcat metrics and Render sizing.
LOADTEST_ADMIN_USER=
LOADTEST_ADMIN_PASS=

# Optional real result writes and write-to-SSE fan-out latency.
LOADTEST_STAFF_USER=
LOADTEST_STAFF_PASS=
ACTIVITY_CARD_ID=
ACTIVITY_MATCH_ID=
ACTIVITY_INTERVAL_MS=10000

# Required for every non-local viewer/API/backend host, comma-separated.
CONFIRM_PRODUCTION_LOAD=
