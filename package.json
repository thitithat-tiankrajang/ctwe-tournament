{
  "name": "ctwe-tournament-manager",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "tsx --test src/application/tournament/*.test.ts src/domain/tournament/*.test.ts src/infrastructure/http/*.test.ts src/ui/pdf/*.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "loadtest": "bash load-testing/scripts/run-load-test.sh",
    "loadtest:preflight": "bash load-testing/scripts/run-load-test.sh --preflight",
    "loadtest:runbook": "tsx load-testing/runbook-generator.ts",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-query-devtools": "^5.59.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.1",
    "tailwind-merge": "^2.6.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.18",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
