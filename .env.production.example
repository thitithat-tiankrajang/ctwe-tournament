# Frontend (Vercel). Set this to the HTTPS Render backend URL.
BACKEND_URL=https://ctwe-tournament-api.onrender.com

# Backend (Render). Never commit real values.
DATABASE_URL=jdbc:postgresql://YOUR_NEON_HOST/YOUR_DATABASE?sslmode=require
DATABASE_USER=YOUR_NEON_ROLE
DATABASE_PASSWORD=YOUR_NEON_PASSWORD
STAFF_USERNAME=YOUR_STAFF_USERNAME
STAFF_PASSWORD_HASH=$2y$12$REPLACE_WITH_A_REAL_BCRYPT_HASH
SESSION_COOKIE_SECURE=true
DEV_TOOLS_ENABLED=false
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=0
